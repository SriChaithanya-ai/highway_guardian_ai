# ============================================================
# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" file.
# ============================================================

# ---------------- Twilio (automated voice call + SMS) --------
# Sign up at https://www.twilio.com  (free trial available)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+10000000000

# ---------------- Email (SMTP) fallback / hospital alerts ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@example.com

# ---------------- Camera / site configuration -----------------
# Latitude/longitude of the CCTV camera used for this pipeline run.
# In production, keep one entry per camera in config/cameras.json instead.
CAMERA_ID=CAM_NH44_KM231
CAMERA_LAT=16.5062
CAMERA_LON=80.6480
RTSP_URL=rtsp://username:password@camera-ip:554/stream1

# ---------------- Emergency dispatch behavior -------------------
# Search radius (meters) used to find the nearest police/hospital via OSM Overpass
NEAREST_SERVICE_RADIUS_M=8000

# Minimum consecutive "accident" frames before an alert is confirmed & dispatched
ACCIDENT_CONFIRMATION_FRAMES=5

# Cooldown (seconds) to avoid re-dispatching for the same ongoing incident
INCIDENT_COOLDOWN_SECONDS=300
